{
  "name": "@composery/ide",
  "license": "MIT",
  "version": "0.0.0",
  "description": "Composery IDE: VS Code in the browser",
  "homepage": "https://github.com/sloikodavid/composery",
  "bugs": {
    "url": "https://github.com/sloikodavid/composery/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sloikodavid/composery"
  },
  "scripts": {
    "clean": "git clean -Xffd",
    "build": "./ci/build/build-code-server.sh",
    "build:vscode": "./ci/build/build-vscode.sh",
    "release": "./ci/build/build-release.sh",
    "test:unit": "./ci/dev/test-unit.sh --forceExit --detectOpenHandles",
    "test:integration": "./ci/dev/test-integration.sh",
    "test:e2e": "VSCODE_IPC_HOOK_CLI= ./ci/dev/test-e2e.sh",
    "test:scripts": "./ci/dev/test-scripts.sh",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e && pnpm run test:scripts",
    "fmt": "pnpm run prettier && ./ci/dev/doctoc.sh",
    "prettier": "prettier --write --log-level=warn --cache .",
    "lint:scripts": "./ci/dev/lint-scripts.sh",
    "lint:ts": "eslint --max-warnings=0 --fix $(git ls-files '*.ts' '*.js' | grep -v 'lib/vscode')",
    "watch": "VSCODE_DEV=1 VSCODE_IPC_HOOK_CLI= NODE_OPTIONS='--max_old_space_size=32384 --trace-warnings' ts-node ./ci/dev/watch.ts",
    "icons": "./ci/dev/gen_icons.sh"
  },
  "main": "out/node/entry.js",
  "devDependencies": {
    "@eslint/compat": "^1.2.0",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.12.0",
    "@jest-mock/express": "^1.4.5",
    "@playwright/test": "^1.56.1",
    "@schemastore/package": "^0.0.10",
    "@types/compression": "^1.7.3",
    "@types/cookie-parser": "^1.4.4",
    "@types/eslint__js": "^8.42.3",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.0.0",
    "@types/http-proxy": "1.17.7",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.6",
    "@types/jsdom": "^16.2.13",
    "@types/node": "22.x",
    "@types/node-fetch": "^2.5.8",
    "@types/pem": "^1.14.1",
    "@types/proxy-from-env": "^1.0.1",
    "@types/qs": "^6.9.7",
    "@types/safe-compare": "^1.1.0",
    "@types/semver": "^7.5.2",
    "@types/trusted-types": "^2.0.4",
    "@types/ws": "^8.5.5",
    "@types/wtfnode": "^0.7.0",
    "doctoc": "^2.2.1",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-prettier": "^5.0.0",
    "extract-zip": "^2.0.1",
    "globals": "^16.1.0",
    "jest": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "jsdom": "^16.4.0",
    "node-fetch": "^2.6.7",
    "playwright": "^1.59.1",
    "prettier": "3.6.2",
    "prettier-plugin-sh": "^0.18.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "wtfnode": "^0.9.1"
  },
  "dependencies": {
    "@coder/logger": "^3.0.1",
    "argon2": "^0.44.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "env-paths": "^2.2.1",
    "express": "^5.0.1",
    "http-proxy": "^1.18.1",
    "httpolyglot": "^0.1.2",
    "i18next": "^25.8.3",
    "js-yaml": "^4.1.0",
    "limiter": "^2.1.0",
    "pem": "^1.14.8",
    "proxy-agent": "^6.3.1",
    "qs": "^6.15.0",
    "rotating-file-stream": "^3.1.1",
    "safe-compare": "^1.1.4",
    "semver": "^7.5.4",
    "ws": "^8.14.2",
    "xdg-basedir": "^4.0.0"
  },
  "bin": {
    "composery": "out/node/entry.js"
  },
  "keywords": [
    "vscode",
    "development",
    "ide",
    "composery",
    "vscode-remote",
    "browser-ide",
    "remote-development"
  ],
  "engines": {
    "node": "22"
  },
  "jest": {
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/",
      "/out/",
      "test/e2e"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "<rootDir>/src/**/*.ts"
    ],
    "coverageDirectory": "<rootDir>/coverage",
    "coverageReporters": [
      "json",
      "json-summary",
      "text",
      "clover"
    ],
    "coveragePathIgnorePatterns": [
      "/out"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60
      }
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/release",
      "<rootDir>/lib"
    ],
    "moduleNameMapper": {
      "^.+\\.(css|less)$": "<rootDir>/test/utils/cssStub.ts"
    },
    "globalSetup": "<rootDir>/test/utils/globalUnitSetup.ts"
  }
}
