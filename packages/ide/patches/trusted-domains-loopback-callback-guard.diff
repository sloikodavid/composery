+	private async promptForLoopbackCallbackLink(link: string, loopbackOrigin: string): Promise<boolean> {
+		const decision = new DeferredPromise<boolean>();
+		let shouldOpen = false;
+		const handle = this._notificationService.prompt(
+			Severity.Warning,
+			localize(
+				'loopbackCallbackGuard',
+				"This link redirects to {0}. Because this is a remote workspace, the redirect may not reach it.",
+				loopbackOrigin,
+			),
+			[
+				{
+					label: localize('openAnyway', 'Open Anyway'),
+					run: () => {
+						shouldOpen = true;
+					}
+				},
+				{
+					label: localize('copy', 'Copy'),
+					run: () => {
+						void this._clipboardService.writeText(link);
+						shouldOpen = false;
+					}
+				}
+			],
+			{
+				sticky: true,
+				onCancel: () => {
+					shouldOpen = false;
+				}
+			},
+		);
+		const onCloseListener = handle.onDidClose(() => {
+			decision.complete(shouldOpen);
+			onCloseListener.dispose();
+		});
+		return decision.p;
+	}
