--- /dev/null
+++ b/lib/vscode/src/vs/workbench/browser/touchGate.ts
@@ -0,0 +1,41 @@
+/*---------------------------------------------------------------------------------------------
+ * Composery: the canonical touch gate - the touch half of the two small-screen gates (the
+ * narrow-viewport half is a width breakpoint, local to narrow-fullscreen.diff). Used by
+ * every feature that branches on touch input (touch-terminal-keybar.diff). Mirrored - but not
+ * importable - in the overlay touch.css/.js; keep the touch query in sync.
+ *--------------------------------------------------------------------------------------------*/
+
+export const TOUCH_QUERY = '(hover: none), (any-pointer: coarse)';
+
+export function isTouch(targetWindow: Window): boolean {
+	return targetWindow.matchMedia(TOUCH_QUERY).matches;
+}
+
+function bottomKeyboardOverlap(targetWindow: Window, rect: DOMRect): number {
+	if (!rect.height) {
+		return 0;
+	}
+
+	const top = rect.y ?? rect.top ?? targetWindow.innerHeight;
+	const bottom = rect.bottom ?? top + rect.height;
+	if (bottom < targetWindow.innerHeight - 1) {
+		return 0;
+	}
+
+	return Math.max(0, Math.round(targetWindow.innerHeight - top));
+}
+
+// Height in px the on-screen keyboard currently occupies at the bottom edge, 0 when hidden or
+// floating. Prefers the Chromium VirtualKeyboard API (reliable on Android when overlaysContent is
+// active) and falls back to visualViewport (iOS Safari).
+export function keyboardInset(targetWindow: Window): number {
+	const virtualKeyboard = (targetWindow.navigator as { virtualKeyboard?: { overlaysContent?: boolean; boundingRect?: DOMRect } }).virtualKeyboard;
+	if (virtualKeyboard?.overlaysContent && virtualKeyboard.boundingRect) {
+		return bottomKeyboardOverlap(targetWindow, virtualKeyboard.boundingRect);
+	}
+	const viewport = targetWindow.visualViewport;
+	if (viewport) {
+		return Math.max(0, Math.round(targetWindow.innerHeight - viewport.height - viewport.offsetTop));
+	}
+	return 0;
+}
