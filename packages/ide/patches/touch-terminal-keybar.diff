+/*---------------------------------------------------------------------------------------------
+ * Composery Mobile Keybar - strip docked above the on-screen keyboard. See
+ * terminalKeybar.contribution.ts. The keyboard inset comes from the Chromium VirtualKeyboard
+ * API (env(keyboard-inset-height)) with the overlay's visualViewport var as the iOS fallback.
+ *--------------------------------------------------------------------------------------------*/
+
+.monaco-workbench .composery-touch-keybar {
+	display: none;
+	position: fixed;
+	left: 0;
+	right: 0;
+	bottom: max(env(keyboard-inset-height, 0px), var(--composery-touch-keyboard-inset, 0px));
+	z-index: 2550;
+	box-sizing: border-box;
+	height: 40px;
+	padding: 0 4px;
+	background-color: var(--vscode-editorWidget-background);
+	border-top: 1px solid var(--vscode-widget-border, var(--vscode-editorWidget-border));
+	overflow-x: auto;
+	overflow-y: hidden;
+	overscroll-behavior: contain;
+	-webkit-overflow-scrolling: touch;
+}
+
+.monaco-workbench .composery-touch-keybar.visible {
+	display: block;
+}
+
+.monaco-workbench .composery-touch-keybar > .actions-container {
+	display: flex;
+	align-items: stretch;
+	gap: 4px;
+	height: 100%;
+	margin: 0;
+	padding: 4px 0;
+	list-style: none;
+}
+
+.monaco-workbench .composery-touch-keybar .action-item {
+	display: flex;
+}
+
+.monaco-workbench .composery-touch-keybar .action-label {
+	display: flex;
+	align-items: center;
+	justify-content: center;
+	min-width: 38px;
+	padding: 0 10px;
+	border-radius: 5px;
+	color: var(--vscode-editorWidget-foreground, var(--vscode-foreground));
+	background-color: var(--vscode-toolbar-hoverBackground, rgba(128, 128, 128, 0.2));
+	font-size: 13px;
+	line-height: 1;
+	white-space: nowrap;
+	cursor: pointer;
+	user-select: none;
+	-webkit-user-select: none;
+	touch-action: manipulation;
+}
+
+.monaco-workbench .composery-touch-keybar .action-label:active {
+	background-color: var(--vscode-toolbar-activeBackground, var(--vscode-toolbar-hoverBackground));
+}
+
+.monaco-workbench .composery-touch-keybar .action-label.checked {
+	color: var(--vscode-inputOption-activeForeground);
+	background-color: var(--vscode-inputOption-activeBackground);
+	box-shadow: inset 0 0 0 1px var(--vscode-inputOption-activeBorder, transparent);
+}
+
+/* Locked (double-tapped) modifier - persists until tapped off; underline marks the difference. */
+.monaco-workbench .composery-touch-keybar .action-label.locked {
+	text-decoration: underline;
+	text-underline-offset: 3px;
+}
