+/**
+ * Convert a logical socket path to the native transport for the platform.
+ * On Windows, Unix domain sockets are often unavailable, so map arbitrary
+ * logical paths to deterministic named pipes. Leave real named-pipe paths
+ * and non-Windows paths untouched.
+ */
+export function toNativeSocketPath(socketPath: string): string {
+  if (process.platform !== "win32" || /^\\\\[^?]\pipe\\/.test(socketPath)) {
+    return socketPath
+  }
+  return path.join("\\\\.", "pipe", "composery-" + crypto.createHash("sha256").update(socketPath).digest("hex"))
+}
