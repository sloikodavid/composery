@@ -180,7 +180,14 @@
 			this.installConfigurationListener();
 			this.installPreferredSchemeListener();
 			this.installRegistryListeners();
-			this.initialize(previousColorThemeSetting).catch(errors.onUnexpectedError);
+			// Composery: re-read the active colour theme from disk after init so a rebuilt
+			// theme overrides the colours VS Code persisted in browser storage, instead of
+			// the stale colours surviving until a fresh browser profile / incognito. The
+			// registry 'added' event that normally triggers this is missed for builtin
+			// themes (it fires before this listener attaches), so force it once here.
+			this.initialize(previousColorThemeSetting)
+				.then(() => this.reloadCurrentColorTheme())
+				.catch(errors.onUnexpectedError);
 		});

 		const codiconStyleSheet = createStyleSheet();
