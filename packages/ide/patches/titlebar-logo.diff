+// Composery: right-click menu for the logo link. Labels and ordering mirror the
+// upstream link context menu in browserViewMainService.ts ("Open Link in New Tab", "Copy Link").
+const COMPOSERY_URL = 'https://www.composery.io';
+
+registerAction2(class extends Action2 {
+	constructor() {
+		super({
+			id: 'composery.openLinkInNewTab',
+			title: localize('composery.openLinkInNewTab', 'Open Link in New Tab'),
+			menu: [{ id: MenuId.TitleBarAppIconContext, order: 1, group: '1_link' }]
+		});
+	}
+	override run(accessor: ServicesAccessor): void {
+		accessor.get(IOpenerService).open(COMPOSERY_URL, { openExternal: true });
+	}
+});
+
+registerAction2(class extends Action2 {
+	constructor() {
+		super({
+			id: 'composery.copyLink',
+			title: localize('composery.copyLink', 'Copy Link'),
+			menu: [{ id: MenuId.TitleBarAppIconContext, order: 2, group: '1_link' }]
+		});
+	}
+	override run(accessor: ServicesAccessor): void {
+		accessor.get(IClipboardService).writeText(COMPOSERY_URL);
+	}
+});
