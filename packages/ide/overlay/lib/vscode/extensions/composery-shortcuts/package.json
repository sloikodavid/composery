{
	"name": "composery-shortcuts",
	"displayName": "Composery Shortcuts",
	"description": "Save and run reusable Composery shortcuts.",
	"version": "0.1.0",
	"publisher": "composery",
	"license": "Apache-2.0",
	"categories": ["Other"],
	"engines": {
		"vscode": "*"
	},
	"extensionKind": ["workspace"],
	"activationEvents": [
		"onStartupFinished",
		"onView:composery.shortcuts.view"
	],
	"main": "./extension.js",
	"contributes": {
		"commands": [
			{
				"command": "composery.shortcuts.run",
				"title": "Run Shortcut",
				"category": "Composery",
				"icon": "$(go-to-file)"
			},
			{
				"command": "composery.shortcuts.add",
				"title": "Add Shortcut",
				"category": "Composery",
				"icon": "$(new-collection)"
			},
			{
				"command": "composery.shortcuts.edit",
				"title": "Edit Shortcut",
				"category": "Composery",
				"icon": "$(edit)"
			},
			{
				"command": "composery.shortcuts.duplicate",
				"title": "Duplicate Shortcut",
				"category": "Composery",
				"icon": "$(copy)"
			},
			{
				"command": "composery.shortcuts.remove",
				"title": "Remove Shortcut",
				"category": "Composery",
				"icon": "$(trash)"
			},
			{
				"command": "composery.shortcuts.moveUp",
				"title": "Move Shortcut Up",
				"category": "Composery",
				"icon": "$(arrow-up)"
			},
			{
				"command": "composery.shortcuts.moveDown",
				"title": "Move Shortcut Down",
				"category": "Composery",
				"icon": "$(arrow-down)"
			},
			{
				"command": "composery.shortcuts.refresh",
				"title": "Refresh Shortcuts",
				"category": "Composery",
				"icon": "$(refresh)"
			},
			{
				"command": "composery.shortcuts.undoRemove",
				"title": "Undo Remove Shortcut",
				"category": "Composery",
				"icon": "$(discard)"
			}
		],
		"views": {
			"explorer": [
				{
					"id": "composery.shortcuts.view",
					"name": "Shortcuts",
					"icon": "$(rocket)"
				}
			]
		},
		"keybindings": [
			{
				"command": "composery.shortcuts.undoRemove",
				"key": "ctrl+z",
				"mac": "cmd+z",
				"when": "focusedView == composery.shortcuts.view"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "composery.shortcuts.add",
					"when": "view == composery.shortcuts.view",
					"group": "navigation"
				},
				{
					"command": "composery.shortcuts.refresh",
					"when": "view == composery.shortcuts.view",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "composery.shortcuts.edit",
					"when": "view == composery.shortcuts.view",
					"group": "inline@1"
				},
				{
					"command": "composery.shortcuts.remove",
					"when": "view == composery.shortcuts.view",
					"group": "inline@2"
				},
				{
					"command": "composery.shortcuts.run",
					"when": "view == composery.shortcuts.view",
					"group": "1_open@1"
				},
				{
					"command": "composery.shortcuts.duplicate",
					"when": "view == composery.shortcuts.view",
					"group": "3_manage@1"
				},
				{
					"command": "composery.shortcuts.moveUp",
					"when": "view == composery.shortcuts.view",
					"group": "3_manage@2"
				},
				{
					"command": "composery.shortcuts.moveDown",
					"when": "view == composery.shortcuts.view",
					"group": "3_manage@3"
				}
			]
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/sloikodavid/composery.git"
	}
}
