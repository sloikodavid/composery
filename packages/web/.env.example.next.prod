# Vercel Production env. NEXT_PUBLIC_CONVEX_URL is injected at build by `convex deploy`,
# so it is not set here. CONVEX_DEPLOYMENT is not used in Vercel.

# Convex - prod: deploy key (Convex dashboard -> Deployment Settings)
CONVEX_DEPLOY_KEY=

# Clerk - production instance (dashboard.clerk.com), pk_live / sk_live
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

CLERK_SECRET_KEY=

CLERK_AUTHORIZED_PARTIES=https://www.composery.io

# Polar - used by lib/polar-dashboard.ts.
NEXT_PUBLIC_POLAR_ENVIRONMENT=production

NEXT_PUBLIC_POLAR_ORGANIZATION_SLUG=

# Hetzner - used by lib/hetzner-dashboard.ts.
NEXT_PUBLIC_HETZNER_PROJECT_ID=

# Vercel - used by lib/vercel-dashboard.ts for the console's "Open in Vercel"
# link (Web Analytics / Speed Insights). The project's dashboard URL,
# https://vercel.com/<team>/<project>. Optional; the link hides when unset.
NEXT_PUBLIC_VERCEL_PROJECT_URL=
