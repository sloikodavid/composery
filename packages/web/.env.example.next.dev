# Local .env.local.

# Clerk - development instance (dashboard.clerk.com), pk_test / sk_test
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

CLERK_SECRET_KEY=

CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=

NEXT_PUBLIC_CONVEX_URL=

NEXT_PUBLIC_CONVEX_SITE_URL=

# Polar - used by lib/polar-dashboard.ts.
NEXT_PUBLIC_POLAR_ENVIRONMENT=sandbox

NEXT_PUBLIC_POLAR_ORGANIZATION_SLUG=

# Hetzner - used by lib/hetzner-dashboard.ts.
NEXT_PUBLIC_HETZNER_PROJECT_ID=

# Vercel - used by lib/vercel-dashboard.ts for the console's "Open in Vercel"
# link (Web Analytics / Speed Insights). The project's dashboard URL,
# https://vercel.com/<team>/<project>. Optional; the link hides when unset.
NEXT_PUBLIC_VERCEL_PROJECT_URL=
