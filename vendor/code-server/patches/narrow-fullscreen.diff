+	//#region Composery narrow-viewport fullscreen parts
+
+	// On a narrow touch viewport exactly one of the side bar / panel / secondary side bar is open at
+	// a time and fills the screen by collapsing the editor beneath it - the setEditorHidden(true)
+	// trick native panel/aux maximize uses, so it reads as a true 1:1 fullscreen with no grid-resize
+	// math; closing the open part reveals the editor again. editorHiddenForFullscreen records that WE
+	// collapsed the editor: it relaxes the editor/panel "both hidden" invariant in setEditorHidden and
+	// keeps isPanelMaximized()/focusPanelOrEditor() from treating the hidden editor as a maximized panel.
+	//
+	// Modeled on native maximize (setAuxiliaryBarMaximized): every part mutation happens synchronously
+	// inside inFullscreenTransition, which the part-visibility relay skips reacting to, so there is no
+	// re-entrant cascade. The open part is tracked as explicit intent (fullscreenPart), not
+	// re-read from transient visibility - so when queued visibility events drain after the transition,
+	// applyFullscreen sees the same intent, finds the state already correct, and converges instead
+	// of oscillating.
+	private static readonly NARROW_CONTENT_PARTS = [Parts.SIDEBAR_PART, Parts.PANEL_PART, Parts.AUXILIARYBAR_PART];
+	private inFullscreenTransition = false;
+	private editorHiddenForFullscreen = false;
+	private fullscreenPart: Parts | undefined;
+	private fullscreenInitialized = false;
+	private fullscreenScheduled = false;
+
+	private get isNarrowViewport(): boolean {
+		return isNarrow(mainWindow);
+	}
+
+	// A content part opened -> it becomes the fullscreen one; the open part closing -> none is. Either
+	// way re-apply, so opening any part also closes the previous one and collapses the editor.
+	private onContentPartVisibility(part: Parts, visible: boolean): void {
+		if (visible) {
+			this.fullscreenPart = part;
+		} else if (part === this.fullscreenPart) {
+			this.fullscreenPart = undefined;
+		}
+		this.scheduleFullscreen();
+	}
+
+	// We are invoked from inside a part-visibility event delivery, so applying immediately would queue
+	// our own part mutations and let the relay react to them once inFullscreenTransition has cleared (a
+	// cascade). Defer to a microtask so the apply runs at top level - synchronous mutations whose events
+	// deliver inside inFullscreenTransition, which the relay then skips, exactly like native maximize. One
+	// microtask coalesces the burst of visibility events a single toggle produces.
+	private scheduleFullscreen(): void {
+		if (this.fullscreenScheduled) {
+			return;
+		}
+		this.fullscreenScheduled = true;
+		queueMicrotask(() => {
+			this.fullscreenScheduled = false;
+			this.applyFullscreen();
+		});
+	}
+
+	private applyFullscreen(): void {
+		if (!this.workbenchGrid || this.inFullscreenTransition || this.inMaximizedAuxiliaryBarTransition) {
+			return;
+		}
+		this.inFullscreenTransition = true;
+		try {
+			// Off a narrow viewport there is no exclusivity or fullscreen - just undo any we applied.
+			if (!this.isNarrowViewport) {
+				this.revealEditorFromFullscreen();
+				return;
+			}
+			const keep = (this.fullscreenPart !== undefined && this.isVisible(this.fullscreenPart))
+				? this.fullscreenPart
+				: undefined;
+			// Exclusivity: at most one content part stays open.
+			let changed = false;
+			for (const part of Layout.NARROW_CONTENT_PARTS) {
+				if (part !== keep && this.isVisible(part)) {
+					this.setPartHidden(true, part);
+					changed = true;
+				}
+			}
+			// Fullscreen: collapse the editor beneath the open part, or reveal it once none is open.
+			if (keep !== undefined) {
+				this.editorHiddenForFullscreen = true;
+				if (this.isVisible(Parts.EDITOR_PART)) {
+					this.setEditorHidden(true);
+					changed = true;
+				}
+				// Hiding the siblings/editor routes focus to the now-collapsed editor, leaving the
+				// fullscreened part (e.g. the terminal) unfocused - so on touch the on-screen keyboard
+				// never opens. Re-focus the open part, exactly as native maximize does (setAuxiliaryBarMaximized).
+				if (changed) {
+					// keep is always one of NARROW_CONTENT_PARTS (side bar / panel / secondary side bar),
+					// all single-window parts - same cast VS Code uses on this trio elsewhere.
+					this.focusPart(keep as SINGLE_WINDOW_PARTS);
+				}
+			} else {
+				this.revealEditorFromFullscreen();
+			}
+		} finally {
+			this.inFullscreenTransition = false;
+		}
+	}
+
+	private revealEditorFromFullscreen(): void {
+		if (this.editorHiddenForFullscreen) {
+			this.editorHiddenForFullscreen = false;
+			if (!this.isVisible(Parts.EDITOR_PART)) {
+				this.setEditorHidden(false);
+			}
+		}
+	}
+
+	//#endregion
+
 	hasMainWindowBorder(): boolean {
