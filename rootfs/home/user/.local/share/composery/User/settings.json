{
	"telemetry.telemetryLevel": "off",
	"security.workspace.trust.enabled": false,
	"window.autoDetectColorScheme": true,
	"editor.fontFamily": "'CommitMono', Menlo, Consolas, 'Ubuntu Mono', monospace",
	"editor.fontSize": 14.5,
	"editor.lineHeight": 1.7,
	"editor.fontLigatures": true,
	"terminal.integrated.fontFamily": "'CommitMono', Menlo, Consolas, 'Ubuntu Mono', monospace",
	"terminal.integrated.fontSize": 14,
	"terminal.integrated.lineHeight": 1.35,
	"chat.editor.fontFamily": "'CommitMono', Menlo, Consolas, 'Ubuntu Mono', monospace",
	"debug.console.fontFamily": "'CommitMono', Menlo, Consolas, 'Ubuntu Mono', monospace",
	"scm.inputFontFamily": "'CommitMono', Menlo, Consolas, 'Ubuntu Mono', monospace",
	"markdown.preview.fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif",
	"markdown.preview.fontSize": 15,
	"markdown.preview.lineHeight": 1.7,
	"workbench.editor.empty.hint": "hidden",
	"workbench.iconTheme": null,
	"workbench.statusBar.visible": false,
	"workbench.activityBar.location": "bottom",
	"breadcrumbs.enabled": false,
	"editor.wordWrap": "on",
	"terminal.integrated.tabs.enabled": false,
	"workbench.panel.showLabels": false,
	"window.menuBarVisibility": "visible",
	"workbench.navigationControl.enabled": false,
	"explorer.compactFolders": false,
	"scm.compactFolders": false,
	"workbench.editor.useModal": "off",
	"editor.scrollbar.vertical": "hidden",
	"editor.tabSize": 2,
	"editor.scrollOnMiddleClick": true,
	"workbench.editor.scrollToSwitchTabs": true,
	"editor.dragAndDrop": false,
	"workbench.editor.wrapTabs": true,
	"window.autoDetectHighContrast": false,
	"editor.cursorBlinking": "smooth",
	"files.exclude": {
		"**/.DS_Store": false,
		"**/.git": false,
		"**/.hg": false,
		"**/.svn": false,
		"**/*.crswap": false,
		"**/Thumbs.db": false
	},
	"editor.linkedEditing": true,
	"editor.wrapOnEscapedLineFeeds": true
}
