{
	"name": "composery",
	"version": "0.1.0",
	"private": true,
	"license": "Apache-2.0",
	"type": "module",
	"packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
	"scripts": {
		"dev": "docker compose up --build",
		"icons": "node scripts/generate-icons.mjs",
		"smoke": "node scripts/smoke.mjs",
		"check": "tsc --noEmit && vitest run --coverage && eslint . && node scripts/check-rust.mjs && node scripts/format.mjs --check && pnpm dlx --package renovate renovate-config-validator renovate.json && symlink-agents --check",
		"fix": "symlink-agents --yes && node scripts/format.mjs --write && eslint . --fix"
	},
	"prettier": {
		"useTabs": true,
		"trailingComma": "none"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@types/node": "25.6.2",
		"@vitest/coverage-v8": "4.1.5",
		"eslint": "10.3.0",
		"png-to-ico": "^3.0.1",
		"prettier": "3.8.3",
		"sharp": "^0.35.0",
		"symlink-agents": "0.2.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.2",
		"vitest": "4.1.5"
	}
}
