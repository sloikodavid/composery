{
	"name": "composery",
	"version": "0.1.0",
	"private": true,
	"license": "Apache-2.0",
	"type": "module",
	"packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
	"scripts": {
		"dev": "docker compose up --build",
		"icons": "node scripts/generate-icons.mjs",
		"smoke": "node scripts/smoke.mjs",
		"check": "tsc --noEmit && vitest run --coverage && eslint . && node scripts/check-rust.mjs && node scripts/format.mjs --check && pnpm dlx --package renovate renovate-config-validator renovate.json && symlink-agents --check",
		"fix": "symlink-agents --yes && node scripts/format.mjs --write && eslint . --fix"
	},
	"prettier": {
		"useTabs": true,
		"trailingComma": "none"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@types/node": "25.6.2",
		"@vitest/coverage-v8": "4.1.5",
		"eslint": "10.3.0",
		"png-to-ico": "^3.0.1",
		"prettier": "3.8.3",
		"sharp": "^0.35.0",
		"symlink-agents": "0.2.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.2",
		"vitest": "4.1.5"
	}
}
